# Version control
.git
.gitignore
.gitattributes

# Dependencies and package-manager artifacts
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs and caches
.next
dist
build
out
coverage
*.tsbuildinfo

# Local environment and secrets
.env
.env.*
!.env.example
secrets/

# Editors and OS files
.vscode
.idea
.DS_Store
*.swp
*.swo
*~

# CI/CD metadata (not needed in image)
.github
.gitlab-ci.yml
.circleci

# Docker and deployment files not required in app image
docker-compose*.yml
certbot/
nginx/

# Local/auxiliary project content not needed for runtime image
demo/
data/
plan/
Resume/
scripts/
src/
test/

# Large local text/log artifacts
*.log
*.tmp

# Optional: keep migration history out of image context (runtime uses generated client)
prisma/migrations/