{
  "name": "personal-website-prototype",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run check:locale-keys && next build",
    "check:locale-keys": "tsc --noEmit --project tsconfig.json",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "prisma:generate": "prisma generate",
    "prisma:seed": "bun prisma/seed.ts",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:crud-example": "bun scripts/prisma-crud-example.ts",
    "integration:auth-db": "bun scripts/integration-auth-db.ts",
    "integration:http-crud": "bun scripts/integration-http-crud.ts",
    "integration:http-admin-users": "bun scripts/integration-http-admin-users.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.7",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "prisma": "^7.6.0",
    "@prisma/adapter-pg": "^5.21.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "prisma",
    "sharp",
    "unrs-resolver"
  ]
}
